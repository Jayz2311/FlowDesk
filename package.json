{
  "name": "task-manager-monorepo",
  "version": "1.0.0",
  "description": "Team Task Management Web Application",
  "scripts": {
    "postinstall": "npm install --prefix backend && npm install --prefix frontend && npm run build:backend",
    "build:backend": "cd backend && npx prisma generate",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend",
    "start": "cd backend && npx prisma db push && node src/index.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.1"
  }
}
